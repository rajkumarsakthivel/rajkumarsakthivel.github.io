---
const navLinks = [
  { href: "#work", label: "Work" },
  { href: "#talks", label: "Talks" },
  { href: "#connect", label: "Connect" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-[#050505]/80 border-b border-white/[0.04]">
  <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="#" class="text-base font-semibold tracking-tight">
      <span class="text-emerald-400 font-mono">//:</span> Ra
    </a>
    <nav class="flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

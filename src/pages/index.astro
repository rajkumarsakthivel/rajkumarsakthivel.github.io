---
import Base from "../layouts/Base.astro";

const talks = [
  { year: "2025", name: "Data Saturdays Sofia", location: "Sofia, Bulgaria" },
  { year: "2025", name: "Michigan Technology Conference", location: "Michigan, USA" },
  { year: "2024", name: "National DevOps Conference", location: "UK" },
  { year: "2024", name: "DevOps Oxford", location: "Oxford, UK" },
];

const expertise = [
  "AI Systems", "LLMs", "LLMOps", "MLOps",
  "Backend Engineering", "Laravel", "Python",
  "Cloud Infrastructure", "DevOps", "Observability",
  "Software Architecture", "Finance & Banking",
];

const socialLinks = [
  { href: "https://github.com/rajkumarsakthivel", label: "GitHub" },
  { href: "https://linkedin.com/in/rajkumar-sakthivel", label: "LinkedIn" },
  { href: "https://x.com/rajkumarsakthi", label: "X" },
  { href: "https://sessionize.com/rajkumar-sakthivel", label: "Sessionize" },
];
---

<Base title="Rajkumar Sakthivel — Engineer, Speaker, Builder">

  <!-- ===== HERO ===== -->
  <section class="grid-bg min-h-screen flex items-center justify-center px-6 relative">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-emerald-500/[0.04] rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-3xl mx-auto text-center relative z-10">
      <p class="fade-up text-sm font-mono text-neutral-500 mb-6 tracking-wider">
        15 years shipping production systems
      </p>

      <h1 class="fade-up fade-up-delay-1 text-5xl sm:text-7xl font-bold tracking-tight leading-[1.1] mb-8">
        I build things that <span class="gradient-text">scale</span>
      </h1>

      <p class="fade-up fade-up-delay-2 text-lg sm:text-xl text-neutral-400 max-w-xl mx-auto mb-10 leading-relaxed">
        Senior Backend Engineer at <span class="text-white font-medium">Tesco</span>.
        From training ML models to operating the infrastructure underneath.
        Currently obsessed with making AI systems work in the real world.
      </p>

      <div class="fade-up fade-up-delay-3 flex items-center justify-center gap-3 flex-wrap mb-16">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-2 text-sm text-neutral-500 hover:text-white border border-white/[0.06] hover:border-white/20 px-4 py-2.5 rounded-full transition-all duration-300"
          >
            {link.label}
            <span class="text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-300">&nearr;</span>
          </a>
        ))}
      </div>

      <div class="fade-up fade-up-delay-4">
        <a href="#work" class="text-neutral-600 hover:text-neutral-400 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mx-auto animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== WHAT I BUILD ===== -->
  <section id="work" class="py-20 sm:py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-mono text-emerald-400 uppercase tracking-[0.2em] mb-4">What I build</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-12">
        From models to <span class="gradient-text">metal</span>
      </h2>

      <div class="grid md:grid-cols-2 gap-5">
        <!-- Card 1: AI Systems -->
        <div class="group p-6 sm:p-8 rounded-2xl border border-white/[0.04] bg-white/[0.01] hover:bg-white/[0.03] glow transition-all duration-500">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">AI Systems</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            Training sentence transformer models, integrating LLM APIs, and operating the private cloud infrastructure underneath.
          </p>
        </div>

        <!-- Card 2: Code Context Engine -->
        <div class="group p-6 sm:p-8 rounded-2xl border border-white/[0.04] bg-white/[0.01] hover:bg-white/[0.03] glow transition-all duration-500">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Code Context Engine</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            Open source tool achieving <span class="text-white font-medium">94% token reduction</span> using tree-sitter AST parsing, vector search, and MCP.
          </p>
        </div>

        <!-- Card 3: Backend -->
        <div class="group p-6 sm:p-8 rounded-2xl border border-white/[0.04] bg-white/[0.01] hover:bg-white/[0.03] glow transition-all duration-500">
          <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Backend at Scale</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            PHP, Laravel, Python, cloud infrastructure, and the observability to keep it all running.
          </p>
        </div>

        <!-- Card 4: Speaking -->
        <div class="group p-6 sm:p-8 rounded-2xl border border-white/[0.04] bg-white/[0.01] hover:bg-white/[0.03] glow transition-all duration-500">
          <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Conference Speaker</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            Hard-won lessons on deploying AI to production, LLMOps, and agentic architectures at scale.
          </p>
        </div>
      </div>

      <!-- Expertise tags -->
      <div class="mt-10 flex flex-wrap gap-2">
        {expertise.map((skill) => (
          <span class="tag">{skill}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TALKS ===== -->
  <section id="talks" class="py-20 sm:py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-mono text-emerald-400 uppercase tracking-[0.2em] mb-4">On stage</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-10">
        Recent <span class="gradient-text">talks</span>
      </h2>

      <div class="space-y-0">
        {talks.map((talk) => (
          <div class="group flex flex-col sm:flex-row sm:items-center justify-between py-5 border-b border-white/[0.04] hover:border-emerald-500/30 transition-colors duration-300">
            <div class="flex items-center gap-4 sm:gap-6">
              <span class="text-xs font-mono text-neutral-600 w-10">{talk.year}</span>
              <span class="text-base sm:text-lg font-medium group-hover:text-emerald-400 transition-colors duration-300">{talk.name}</span>
            </div>
            <span class="text-sm text-neutral-600 ml-14 sm:ml-0 mt-1 sm:mt-0">{talk.location}</span>
          </div>
        ))}
      </div>

      <div class="mt-8">
        <a
          href="https://sessionize.com/rajkumar-sakthivel"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-emerald-400 hover:text-emerald-300 transition-colors"
        >
          Invite me to speak
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== BACKGROUND ===== -->
  <section class="py-20 sm:py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <p class="text-xs font-mono text-emerald-400 uppercase tracking-[0.2em] mb-4">Education</p>
          <h3 class="text-lg font-semibold mb-1">University of Oxford</h3>
          <p class="text-sm text-neutral-500">2022 – 2024</p>
        </div>
        <div>
          <p class="text-xs font-mono text-emerald-400 uppercase tracking-[0.2em] mb-4">Certifications</p>
          <p class="text-sm text-neutral-400 mb-2">Numerical Methods for Stochastic Differential Equations, IIT Roorkee</p>
          <p class="text-sm text-neutral-400">Randomized Methods for Approximation & Parameterized Algorithms, IIT Gandhinagar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CONNECT ===== -->
  <section id="connect" class="py-20 sm:py-24 px-6 relative">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-emerald-500/[0.03] rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-3xl mx-auto text-center relative z-10">
      <p class="text-xs font-mono text-emerald-400 uppercase tracking-[0.2em] mb-4">Get in touch</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">
        Let's <span class="gradient-text">connect</span>
      </h2>
      <p class="text-neutral-400 mb-10 max-w-md mx-auto">
        AI systems, open source, speaking opportunities, or just saying hello.
      </p>
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href="https://linkedin.com/in/rajkumar-sakthivel"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium bg-emerald-500 hover:bg-emerald-400 text-[#050505] px-6 py-3 rounded-full transition-colors duration-300"
        >
          LinkedIn
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </a>
        <a
          href="https://github.com/rajkumarsakthivel"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium border border-white/10 hover:border-white/25 text-white px-6 py-3 rounded-full transition-all duration-300"
        >
          GitHub
        </a>
        <a
          href="https://x.com/rajkumarsakthi"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium border border-white/10 hover:border-white/25 text-white px-6 py-3 rounded-full transition-all duration-300"
        >
          X
        </a>
      </div>
    </div>
  </section>

</Base>

---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page not found">
  <section class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="text-8xl font-bold font-mono text-emerald-400/20 mb-4">404</p>
      <h1 class="text-2xl font-semibold mb-3">Page not found</h1>
      <p class="text-neutral-500 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-medium bg-emerald-500 hover:bg-emerald-400 text-[#050505] px-5 py-2.5 rounded-full transition-colors duration-300"
      >
        Back to home
      </a>
    </div>
  </section>
</Base>
